# ===== Kirana SaaS — production env =====
# Copy to `.env.production` and fill in real secrets. NEVER commit the real file.

NODE_ENV=production
PORT=4000
APP_URL=https://your-domain.com
TRUST_PROXY=1
LOG_LEVEL=info

# Comma-separated list of allowed origins. Avoid `*` in production.
CORS_ORIGINS=https://your-domain.com,https://admin.your-domain.com

# ----- Auth -----
# MUST be a strong random string >= 32 chars. Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
JWT_SECRET=replace_me_with_a_strong_random_string_at_least_32_chars
JWT_EXPIRES_IN=7d

# ----- Database (PostgreSQL) -----
DB_DIALECT=postgres
DB_HOST=db
DB_PORT=5432
DB_NAME=kirana_saas
DB_USER=kirana
DB_PASSWORD=replace_me_with_strong_db_password
DB_SSL=false
DB_POOL_MAX=10
RUN_MIGRATIONS=true

# ----- Rate limiting -----
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300
RATE_LIMIT_PUBLIC_MAX=60
RATE_LIMIT_AUTH_MAX=10

# ----- Razorpay (https://dashboard.razorpay.com/) -----
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# ----- WhatsApp Cloud API (https://developers.facebook.com/) -----
WHATSAPP_API_URL=https://graph.facebook.com/v20.0
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=

# ----- SaaS plans -----
TRIAL_DAYS=14
