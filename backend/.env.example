# Server
NODE_ENV=development
PORT=4000
API_BASE_PATH=/api/v1

# Database — set DB_DIALECT=sqlite for zero-setup local dev (recommended to start)
DB_DIALECT=sqlite
DB_STORAGE=./data/kirana.sqlite

# Postgres (used when DB_DIALECT=postgres)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=kirana_saas
DB_USER=postgres
DB_PASSWORD=postgres
DB_SSL=false

# JWT
JWT_SECRET=replace_me_with_a_long_random_secret
JWT_EXPIRES_IN=7d

# Razorpay
RAZORPAY_KEY_ID=rzp_test_xxx
RAZORPAY_KEY_SECRET=xxx

# WhatsApp Cloud API
WHATSAPP_API_URL=https://graph.facebook.com/v20.0
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=verify_me
WHATSAPP_APP_SECRET=

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300

# Subscription
TRIAL_DAYS=14
